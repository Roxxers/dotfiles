        "less",
        "markdown",
        "php",
        "pip-requirements",
        "plaintext",
        "pug",
        "python",
        "restructuredtext",
        "rust",
        "scala",
        "scss",
        "shellscript",
        "text",
        "typescript",
        "typescriptreact",
        "xml",
        "yaml",
        "yml"
    ],
    "workbench.colorTheme": "Monokai Sweet Darker",
    "docker.dockerComposeDetached": false,
    "docker.dockerComposeBuild": false,
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "docker.containers.label": "ContainerName"
}