{
    "editor.fontFamily": "Fira Code",
    "vsicons.dontShowNewVersionMessage": true,
    "git.allowForcePush": true,
    "git.enableCommitSigning": true,
    "git.enableSmartCommit": true,
    "git.autofetch": true,
    "spellright.addToSystemDictionary": true,
    "spellright.language": [
        "english-uk"
    ],
    "cSpell.userWords": [
        "TYPECHECK",
        "Tariq",
        "abstractproperty",
        "asdict",
        "basestring",
        "builtins",
        "chown",
        "classmethod",
        "codium",
        "concat",
        "contextlib",
        "contextmanager",
        "delslice",
        "docstring",
        "docstrings",
        "dotenv",
        "dotfiles",
        "execfile",
        "from",
        "getenv",
        "getslice",
        "healthcheck",
        "ibtehal",
        "idiv",
        "inlinevar",
        "isfile",
        "itertools",
        "libpq",
        "metaclass",
        "msvs",
        "mymodule",
        "mypackage",
        "ncdu",
        "nvim",
        "oauth",
        "optparse",
        "organisation",
        "organisation's",
        "organsation",
        "overgeneral",
        "paren",
        "parseable",
        "postgres",
        "postgresql",
        "pyfile",
        "pygtk",
        "pylint",
        "pywal",
        "rcfile",
        "reddit",
        "reenable",
        "regexes",
        "request",
        "roxxers",
        "setslice",
        "siana",
        "standarderror",
        "strftime",
        "strptime",
        "submodules",
        "tkinter",
        "tldr",
        "unichr",
        "urllib",
        "venv",
        "vs",
        "xrange",
        "xreadlines"
    ],
    "editor.fontLigatures": true,
    "workbench.iconTheme": "simple-icons",
    "gitlens.codeLens.enabled": false,
    "gitlens.statusBar.enabled": false,
    "gitlens.views.repositories.location": "scm",
    "gitlens.views.fileHistory.location": "scm",
    "gitlens.views.search.enabled": false,
    "gitlens.views.compare.enabled": false,
    "cSpell.enabledLanguageIds": [
        "asciidoc",
        "c",
        "cpp",
        "css",
        "dockerfile",
        "dotenv",
        "git-commit",
        "git-rebase",
        "go",
        "go.mod",
        "go.sum",
