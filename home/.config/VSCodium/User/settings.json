{
    "editor.fontFamily": "Fira Code",
    "vsicons.dontShowNewVersionMessage": true,
    "git.allowForcePush": true,
    "git.enableCommitSigning": true,
    "git.enableSmartCommit": true,
    "git.autofetch": true,
    "spellright.addToSystemDictionary": true,
    "spellright.language": [
        "english-uk"
    ],
    "cSpell.userWords": [
        "Referer",
        "TYPECHECK",
        "Tariq",
        "WORKDIR",
        "abstractproperty",
        "aiohttp",
        "asdict",
        "asyncio",
        "basestring",
        "beautifulsoup",
        "builtins",
        "chown",
        "classmethod",
        "codium",
        "concat",
        "contextlib",
        "contextmanager",
        "delslice",
        "docstring",
        "docstrings",
        "dotenv",
        "dotfiles",
        "execfile",
        "from",
        "getcwd",
        "getenv",
        "getslice",
        "godotenv",
        "healthcheck",
        "ibtehal",
        "idiv",
        "inlinevar",
        "isdir",
        "isfile",
        "itertools",
        "libpq",
        "metaclass",
        "msvs",
        "mymodule",
        "mypackage",
        "ncdu",
        "nvim",
        "oauth",
        "optparse",
        "organisation",
        "organisation's",
        "organsation",
        "overgeneral",
        "paren",
        "parseable",
        "postgres",
        "postgresql",
        "pyfile",
        "pygtk",
        "pylint",
        "pywal",
        "pyyaml",
        "rcfile",
        "reddit",
        "reenable",
        "regexes",
        "request",
        "roxxers",
        "setslice",
        "siana",
        "standarderror",
        "strftime",
        "strptime",
        "submodules",
        "tkinter",
        "tldr",
        "unichr",
        "urllib",
        "venv",
        "vs",
        "xrange",
        "xreadlines"
    ],
    "editor.fontLigatures": true,
    "workbench.iconTheme": "simple-icons",
    "gitlens.codeLens.enabled": false,
    "gitlens.statusBar.enabled": false,
    "gitlens.views.repositories.location": "scm",
    "gitlens.views.fileHistory.location": "scm",
    "gitlens.views.search.enabled": false,
    "gitlens.views.compare.enabled": false,
    "cSpell.enabledLanguageIds": [
        "asciidoc",
        "c",
        "cpp",
        "css",
        "dockerfile",
        "dotenv",
        "git-commit",
        "git-rebase",
        "go",
        "go.mod",
        "go.sum",
        "html",
        "jade",
        "java",
        "javascript",
        "javascriptreact",
        "json",
        "jsonc",
        "latex",
        "less",
        "markdown",
        "php",
        "pip-requirements",
        "plaintext",
        "pug",
        "python",
        "restructuredtext",
        "rust",
        "scala",
        "scss",
        "shellscript",
        "text",
        "typescript",
        "typescriptreact",
        "xml",
        "yaml",
        "yml"
    ],
    "docker.dockerComposeDetached": false,
    "docker.dockerComposeBuild": false,
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "docker.containers.label": "ContainerName",
    "terminal.external.linuxExec": "xterm-kitty",
    "terminal.integrated.fontFamily": "inconsolata nerd font",
    "terminal.integrated.fontSize": 15,
    "go.formatTool": "goimports",
    "go.useLanguageServer": true,
    "files.associations": {
        "*.go": "go"
    },
    "telemetry.enableCrashReporter": false,
    "workbench.settings.enableNaturalLanguageSearch": false,
    "update.showReleaseNotes": false,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "variable.parameter.function.language.special.self.python",
                    "variable.language.special.self.python"
                ],
                "settings": {
                    "foreground": "#7d61b3",
                    "fontStyle": "italic"
                }
            },
            {
                "scope": [
                    "comment.line",
                ],
                "settings": {
                    "fontStyle": "italic"
                }
            }
        ]
    },
    "autoDocstring.docstringFormat": "google",
    "autoDocstring.includeName": true,
    "workbench.colorTheme": "Monokai Sweet Darker",
    "editor.suggestSelection": "first",
    "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
    "python.jediEnabled": false
}